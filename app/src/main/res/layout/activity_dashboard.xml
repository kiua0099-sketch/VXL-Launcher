<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0A0A0A"
    android:weightSum="10">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.5"
        android:background="#121212"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VX"
            android:textColor="#FF0000"
            android:textSize="32sp"
            android:textStyle="bold|italic"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btn_nav_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#FFFFFF"
            android:backgroundTint="#22FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_nav_store"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mod Store"
            android:textColor="#FF9999"
            android:backgroundTint="#11FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_nav_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FF9999"
            android:backgroundTint="#11FFFFFF"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="7.5"
        android:padding="24dp">

        <TextView
            android:id="@+id/txt_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DASHBOARD"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"/>

        <LinearLayout
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerInParent="true"
            android:background="#161616"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offline Username:"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edt_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Player Name"
                android:textColorHint="#44FFFFFF"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF0000"
                android:inputType="text"/>
            
            <Spinner
                android:id="@+id/spinner_loaders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="#FF0000"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_play"
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:text="PLAY GAME"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FF0000"
            android:elevation="8dp"/>

        <TextView
            android:id="@+id/txt_dashboard_ai_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentLeft="true"
            android:text="VX AI: Core System Engaged &amp; Stable."
            android:textColor="#66FFFFFF"
            android:textSize="11sp"/>

    </RelativeLayout>
</LinearLayout>
